{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "caption": {
          "type": "text",
          "settings": {
            "text": "{{ product.metafields.descriptors.subtitle.value }}",
            "text_style": "subtitle"
          }
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "description": {
          "type": "description"
        },
        "collapsible-row-0": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Benefits",
            "icon": "heart",
            "content": "<p>Light textures, a simple routine, and clear messaging help customers choose with confidence.</p>",
            "page": ""
          }
        },
        "collapsible-row-1": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Key ingredients",
            "icon": "leaf",
            "content": "<p>Fictional actives inspired by contemporary skincare: niacinamide, antioxidants, ceramides, and botanical extracts.</p>",
            "page": ""
          }
        },
        "collapsible-row-2": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "How to use",
            "icon": "check_mark",
            "content": "<p>Apply during the recommended routine step. In the morning, finish with sunscreen. At night, pair with moisturizer.</p>",
            "page": ""
          }
        },
        "collapsible-row-3": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping and returns",
            "icon": "truck",
            "content": "<p>Demo content: shipping, return policy, and delivery timelines should be configured in the real store admin.</p>",
            "page": ""
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "caption",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "description",
        "collapsible-row-0",
        "collapsible-row-1",
        "collapsible-row-2",
        "collapsible-row-3",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "routine": {
      "type": "lumae-routine",
      "blocks": {
        "step_1": {
          "type": "step",
          "settings": {
            "title": "Morning",
            "text": "<p>Gentle cleanse, antioxidant serum, moisturizer, and SPF.</p>"
          }
        },
        "step_2": {
          "type": "step",
          "settings": {
            "title": "Night",
            "text": "<p>Cleanse, treat, and seal with a nourishing texture.</p>"
          }
        },
        "step_3": {
          "type": "step",
          "settings": {
            "title": "No excess",
            "text": "<p>Organized information for a faster, more confident purchase.</p>"
          }
        }
      },
      "block_order": [
        "step_1",
        "step_2",
        "step_3"
      ],
      "settings": {
        "eyebrow": "How it fits your routine",
        "heading": "Choose by moment of use.",
        "text": "<p>The product page complements admin product data with guidance, benefits, and purchase answers.</p>"
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "Complete your routine",
        "heading_size": "h2",
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "square",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 56
      }
    }
  },
  "order": [
    "main",
    "routine",
    "related-products"
  ]
}
