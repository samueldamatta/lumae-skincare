<section class="lumae-proof">
  <div class="lumae-page-width">
    <div class="lumae-proof__header">
      {% if section.settings.eyebrow != blank %}
        <p class="lumae-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="lumae-proof__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="lumae-proof__intro">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="lumae-proof__grid">
      {% for block in section.blocks %}
        <article class="lumae-proof-card" {{ block.shopify_attributes }}>
          {% if block.settings.title != blank %}
            <h3 class="lumae-proof-card__title">{{ block.settings.title | escape }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="lumae-proof-card__text">{{ block.settings.text }}</div>
          {% endif %}
          {% if block.settings.meta != blank %}
            <p class="lumae-proof-card__meta">{{ block.settings.meta | escape }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lumae proof",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Social proof"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A store designed to convert without feeling generic."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Fictional testimonials help demonstrate hierarchy, trust, and storytelling in the shopping flow.</p>"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Light texture"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>The routine feels premium while staying easy to understand.</p>"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta",
          "default": "Fictional customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lumae proof",
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "title": "Light texture",
            "text": "<p>The routine feels premium while staying easy to understand.</p>",
            "meta": "Fictional customer"
          }
        },
        {
          "type": "quote",
          "settings": {
            "title": "Guided shopping",
            "text": "<p>The pages make it clear which product belongs to each moment of the routine.</p>",
            "meta": "UX test"
          }
        },
        {
          "type": "quote",
          "settings": {
            "title": "Consistent visuals",
            "text": "<p>The art direction supports a premium perception across the entire journey.</p>",
            "meta": "Portfolio case"
          }
        }
      ]
    }
  ]
}
{% endschema %}
